[resource]
; ============================================================================
; FONT COLORS
; ============================================================================
; Header/Bright (for KPIs, important metrics)
Label/colors/header_bright = Color(1, 1, 1, 1)
Label/colors/header_cyan = Color(0.1, 1, 1, 1)
Label/colors/header_magenta = Color(1, 0.45, 1, 1)

; Body (default text)
Label/colors/font_color = Color(0.78431374, 0.29411766, 1, 1)
Label/colors/body_text = Color(0.78431374, 0.29411766, 1, 0.9)
Label/colors/body_muted = Color(0.6, 0.5, 0.7, 0.8)

; Disabled/Dim
Label/colors/disabled_text = Color(0.4, 0.35, 0.45, 0.7)
Label/colors/font_outline_color = Color(0.07058824, 0, 0.08235294, 1)

; Accent Colors
Label/colors/accent_green = Color(0.45, 1, 0.05, 1)
Label/colors/accent_red = Color(1, 0.2, 0.2, 1)
Label/colors/accent_cyan = Color(0.1, 1, 1, 1)
Label/colors/accent_magenta = Color(1, 0.4, 0.9, 1)
Label/colors/accent_yellow = Color(1, 0.85, 0, 1)

; ============================================================================
; FONT SIZES
; ============================================================================
Label/font_sizes/header_size = 22
Label/font_sizes/title_size = 20
Label/font_sizes/normal_size = 13
Label/font_sizes/small_size = 11
Label/font_sizes/tiny_size = 9

; ============================================================================
; TEXT OUTLINE
; ============================================================================
Label/constants/outline_size = 2
Label/constants/line_spacing = 4

; ============================================================================
; BUTTON COLORS & STYLES
; ============================================================================
Button/colors/font_color = Color(0.78431374, 0.29411766, 1, 1)
Button/colors/font_hover_color = Color(1, 0.7, 1, 1)
Button/colors/font_pressed_color = Color(0.8, 0.3, 0.9, 1)
Button/colors/font_disabled_color = Color(0.4, 0.35, 0.45, 0.7)
Button/colors/font_outline_color = Color(0.07058824, 0, 0.08235294, 1)
Button/colors/font_focus_color = Color(1, 1, 1, 1)

Button/font_sizes/font_size = 13
Button/constants/outline_size = 1

Button/styles/normal = SubResource("ButtonUnaffordableStyle")
Button/styles/hover = SubResource("ButtonAffordableStyle")
Button/styles/pressed = SubResource("ButtonAffordableStyle")
Button/styles/focus = SubResource("ButtonAffordableStyle")
Button/styles/disabled = SubResource("ButtonUnaffordableStyle")

; ============================================================================
; PANEL STYLES
; ============================================================================
PanelContainer/styles/panel = SubResource("PanelActiveStyle")

Panel/styles/panel = SubResource("PanelActiveStyle")
Panel/styles/panel_header = SubResource("PanelHeaderStyle")

; ============================================================================
; PROGRESS BAR
; ============================================================================
ProgressBar/colors/font_color = Color(0.45, 1, 0.05, 1)
ProgressBar/colors/font_outline_color = Color(0.07058824, 0, 0.08235294, 1)
ProgressBar/font_sizes/font_size = 12
ProgressBar/constants/outline_size = 1
ProgressBar/styles/background = SubResource("ProgressBarStyle")
ProgressBar/styles/fill = SubResource("ProgressBarFillStyle")

; ============================================================================
; SCROLL CONTAINER
; ============================================================================
ScrollContainer/colors/font_color = Color(0.78431374, 0.29411766, 1, 1)

; ============================================================================
; SPACING & CONSTANTS
; ============================================================================
HBoxContainer/constants/separation = 8
VBoxContainer/constants/separation = 8
MarginContainer/constants/margin_left = 8
MarginContainer/constants/margin_top = 8
MarginContainer/constants/margin_right = 8
MarginContainer/constants/margin_bottom = 8

; ============================================================================
; RICHTEXT DEFAULTS
; ============================================================================
RichTextLabel/colors/default_color = Color(0.78431374, 0.29411766, 1, 0.9)
RichTextLabel/colors/font_color = Color(0.78431374, 0.29411766, 1, 0.9)
RichTextLabel/font_sizes/normal_font_size = 12
default_font = SubResource("DefaultFontWithEmoji")
