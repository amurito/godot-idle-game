; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HYPHAE: genesis"
config/description="Simulación de sistemas adaptativos: gestioná un organismo en evolución, alcanzá la homeostasis y trascendé el ciclo biótico. Idle/incremental con mutaciones, trueque y herencia cósmica."
config/version="1.0.0"
run/main_scene="res://MainMenu.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
boot_splash/image="uid://cekpw5ea8gtbw"
config/icon="res://icon.png"

[autoload]

Version="*res://version.gd"
SlotManager="*res://SlotManager.gd"
LegacyManager="*res://LegacyManager.gd"
SaveManager="*res://SaveManager.gd"
EcoModel="*res://EcoModel.gd"
BiosphereEngine="*res://BiosphereEngine.gd"
EvoManager="*res://EvoManager.gd"
UIManager="*res://UIManager.gd"
LogManager="*res://LogManager.gd"
UpgradeManager="*res://UpgradeManager.gd"
AchievementManager="*res://AchievementManager.gd"
RunManager="*res://RunManager.gd"
RouteManager="*res://RouteManager.gd"
EconomyManager="*res://EconomyManager.gd"
StructuralModel="*res://StructuralModel.gd"
EmojiToRichText="*res://EmojiToRichText.gd"
AudioManager="*res://AudioManager.gd"
TutorialManager="*res://TutorialManager.gd"
TelemetryManager="*res://TelemetryManager.gd"
AccessibilityManager="*res://AccessibilityManager.gd"
LocaleManager="*res://LocaleManager.gd"
Balance="*res://Balance.gd"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"
general/default_playback_type.web=1

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"
general/default_playback_type.web=1

[editor]

version_control/autoload_on_startup=true

[global_group]

fungi_ui=""

[input]

ui_debug={
